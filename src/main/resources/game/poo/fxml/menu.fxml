<?xml version="1.0" encoding="UTF-8"?>

<?import Elements.BotaoGrupo?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="474.0" prefWidth="637.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.poo.controllers.MenuController">
   <children>
      <VBox layoutX="20"
            layoutY="20"
            spacing="10">
         <children>
            <BotaoGrupo
                fx:id="grupo1"
                text="Tutorial"
                descricao="Descrição do Grupo Tutorial"
                onAction="#enviarInfos"
                prefWidth="180"/>

            <BotaoGrupo
                fx:id="grupo2"
                text="Variáveis"
                descricao="Descrição do Grupo Variáveis"
                onAction="#enviarInfos"
                prefWidth="180"/>

            <BotaoGrupo
                fx:id="grupo3"
                text="Condicionais"
                descricao="Descrição do Grupo Condicionais"
                onAction="#enviarInfos"
                prefWidth="180"/>
         </children>
      </VBox>
      <Label text="Descrição:" layoutX="250" layoutY="30" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

      <Label fx:id="descricao" layoutX="250" layoutY="70" prefWidth="340" wrapText="true" text="Selecione um grupo." style="-fx-font-size: 14px;"/>
      
      <Button fx:id="entrar" text="ENTRAR" layoutX="250" layoutY="180" prefWidth="120" prefHeight="35"/>
   </children>
</AnchorPane>