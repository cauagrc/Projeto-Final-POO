<?xml version="1.0" encoding="UTF-8"?>

<?import Elements.BotaoCena?>
<?import Elements.BotaoGrupo?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="474.0"
            prefWidth="637.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="game.poo.grupos.GrupoTutorial">

    <!-- Lista de fases -->
    <left>
        <ScrollPane fitToWidth="true"
                    prefWidth="210"
                    BorderPane.alignment="CENTER">

            <content>
                <VBox spacing="10" fillWidth="true">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <children>

                        <BotaoGrupo
                                fx:id="fase1"
                                text="Fase 1"
                                descricao="Descrição da Fase 1"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase2"
                                text="Fase 2"
                                descricao="Descrição da Fase 2"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase3"
                                text="Fase 3"
                                descricao="Descrição da Fase 3"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase4"
                                text="Fase 4"
                                descricao="Descrição da Fase 4"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase5"
                                text="Fase 5"
                                descricao="Descrição da Fase 5"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase6"
                                text="Fase 6"
                                descricao="Descrição da Fase 6"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase7"
                                text="Fase 7"
                                descricao="Descrição da Fase 7"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase8"
                                text="Fase 8"
                                descricao="Descrição da Fase 8"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase9"
                                text="Fase 9"
                                descricao="Descrição da Fase 9"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                        <BotaoGrupo
                                fx:id="fase10"
                                text="Fase 10"
                                descricao="Descrição da Fase 10"
                                onAction="#enviarInfos"
                                prefWidth="170"/>

                    </children>
                </VBox>
            </content>

        </ScrollPane>
    </left>

    <!-- Painel da direita -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <children>

                <Label text="Descrição:"
                       style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                <Label fx:id="descricao"
                       wrapText="true"
                       prefWidth="360"
                       style="-fx-font-size:14px;"
                       text="Selecione um grupo."/>

                <Region VBox.vgrow="ALWAYS"/>

                <BotaoCena fx:id="bEntrar"
                           text="ENTRAR"
                           prefWidth="140"/>

                <BotaoCena fx:id="bVoltar"
                           text="VOLTAR"
                           prefWidth="140"/>

            </children>
        </VBox>
    </center>

</BorderPane>